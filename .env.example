# Copy this file to .env at the repo root and adjust values as needed.

# Application
APP_NAME=EventFlow
ENVIRONMENT=local
DEBUG=True
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+asyncpg://eventflow:eventflow@db:5432/eventflow
SYNC_DATABASE_URL=postgresql://eventflow:eventflow@db:5432/eventflow

# Redis
REDIS_URL=redis://redis:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_ORDER_EVENTS_TOPIC=order-events
KAFKA_INVENTORY_EVENTS_TOPIC=inventory-events
KAFKA_PAYMENT_EVENTS_TOPIC=payment-events
KAFKA_SHIPPING_EVENTS_TOPIC=shipping-events
KAFKA_WORKFLOW_EVENTS_TOPIC=workflow-events
KAFKA_NOTIFICATION_EVENTS_TOPIC=notification-events

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Host port overrides (when defaults are already in use on your machine)
# POSTGRES_HOST_PORT=5433
# REDIS_HOST_PORT=6380
